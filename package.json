{
  "name": "needline",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "bun run build && bun build/index.js",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "drizzle-kit generate --config=src/lib/server/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate  --config=src/lib/server/db/drizzle.config.ts",
    "db:push": "drizzle-kit push     --config=src/lib/server/db/drizzle.config.ts",
    "db:studio": "drizzle-kit studio   --config=src/lib/server/db/drizzle.config.ts",
    "codegen": "graphql-codegen"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@graphql-codegen/typescript": "^6.0.2",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.17.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "@linear/sdk": "^86.0.0",
    "@types/bun": "^1.3.14",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "graphql-request": "^7.4.0",
    "valibot": "^1.4.1"
  }
}
